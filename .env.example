# AliMeeting Diarization Bench Environment Variables

# DashScope API (required for qwen3-asr-flash, qwen3.5-omni-plus, Fun-ASR, paraformer-v2)
DASHSCOPE_API_KEY=sk-your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OSS credentials (required for Fun-ASR and paraformer-v2 which need file upload)
OSS_ACCESS_KEY_ID=LTAIyour-access-key
OSS_ACCESS_KEY_SECRET=your-secret-key
OSS_BUCKET=speaker-color-test
OSS_REGION=cn-beijing
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com

# HuggingFace token (required for PyAnnote 3.1)
HF_TOKEN=hf-your-huggingface-token

# GPT API key (required for gpt-4o-audio-preview)
GPT_API_KEY=sk-your-gpt-key

# Data paths (optional - defaults shown)
ALIMEETING_MANIFEST_DIR=~/data/AliMeeting/AliMeeting_manifests
ALIMEETING_AUDIO_DIR=~/data/AliMeeting/Eval_Ali/Eval_Ali_far/audio_dir
ALIMEETING_OUTPUT_DIR=~/data/AliMeeting/batch_results
